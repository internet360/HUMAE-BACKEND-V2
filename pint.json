{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "strict_param": true,
        "strict_comparison": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "concat_space": {
            "spacing": "none"
        },
        "not_operator_with_successor_space": true,
        "single_trait_insert_per_statement": true
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor"
    ]
}

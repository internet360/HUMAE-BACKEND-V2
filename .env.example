APP_NAME=HUMAE
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Mexico_City

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -- Database (MySQL 8) --
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=humae
DB_USERNAME=root
DB_PASSWORD=

# -- Session / Cache / Queue --
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -- Mail (SMTP local — Postfix/OpenSMTPD en el mismo servidor que el backend) --
# En dev con docker-compose: MAIL_HOST=mailhog MAIL_PORT=1025
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@humae.com.mx"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_REPLY_TO="soporte@humae.com.mx"

# -- Sanctum --
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# -- Frontend CORS --
FRONTEND_URL=http://localhost:3000

# -- Stripe (membresías) --
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=mxn
STRIPE_PRICE_CANDIDATE_6M=

# -- Membership plan defaults --
MEMBERSHIP_AMOUNT_MXN=499
MEMBERSHIP_DURATION_MONTHS=6

# -- Sentry (observabilidad) --
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# -- Scribe API docs --
SCRIBE_AUTH_KEY=
